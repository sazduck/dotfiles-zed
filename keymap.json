      "space r": "editor::Rename",
    },
  },
  {
    "context": "CommandPalette",
    "bindings": {
      "ctrl-[": "command_palette::Toggle",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore",
    },
  },
]
