// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "CommandPalette",
    "bindings": {
      "ctrl-[": "command_palette::Toggle",
    },
  },
  // {
  //   "context": "Editor && edit_prediction)",
  //   "bindings": {
  //     "tab": null,
  //   },
  // },
  // {
  //   "context": "(Editor && showing_completions)",
  //   "bindings": {
  //     "tab": null,
  //   },
  // },
  {
    "context": "Editor && in_snippet && has_next_tabstop",
    "bindings": {
      "tab": "editor::NextSnippetTabstop",
    },
  },
  {
    "context": "(Editor && mode == full)",
    "bindings": {
      "alt-z": "editor::ToggleSoftWrap",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-alt-z": "workspace::ToggleVimMode",
    },
  },
  {
    "context": "Editor && !menu",
    "bindings": {
      "ctrl-shift-c": "editor::Copy",
      "ctrl-shift-v": "editor::Paste",
      "ctrl-shift-a": "editor::SelectAll",
      "ctrl-shift-x": "editor::Cut",
      "ctrl-y": "editor::Redo", // vim default: line up
      "ctrl-e": "file_finder::Toggle", // vim default: line down
    },
  },
  {
    "context": "Editor && !menu",
    "bindings": {
      "ctrl-[": "editor::Cancel",
    },
    "unbind": {
      "ctrl-[": "editor::Outdent",
    },
  },

  {
    "context": "!Terminal",
    "bindings": {
      "alt-b": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "Editor && edit_prediction && edit_prediction_mode == eager && !showing_completions",
    "unbind": {
      "tab": "editor::AcceptEditPrediction",
    },
  },
  {
    "context": "Workspace && !Terminal",
    "bindings": {
      "ctrl-p": "file_finder::Toggle",
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-p": "file_finder::Toggle",
    },
  },
  {
    "context": "Terminal",
    "unbind": {
      "ctrl-n": "workspace::NewTerminal",
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-n": "workspace::NewFile",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-[": "editor::Outdent",
    },
    "bindings": {
      "ctrl-[": "editor::Cancel",
    },
  },
  {
    "context": "InlineAssistant",
    "unbind": {
      "ctrl-[": "agent::CyclePreviousInlineAssist",
    },
  },
]
